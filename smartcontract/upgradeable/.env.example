# Foundry Environment Variables for UUPS Deployment

# Private key for deployment (DO NOT COMMIT ACTUAL KEY!)
PRIVATE_KEY=0xYourPrivateKeyHere

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# BaseScan API Key for contract verification
BASESCAN_API_KEY=YourBaseScanApiKeyHere

# Proxy addresses (for upgrades)
PROXY_ADDRESS=0xYourProxyAddressHere

# Optional: Gnosis Safe multisig address (for production ownership transfer)
MULTISIG_ADDRESS=0xYourMultisigAddressHere
